# Copy this file to .env and fill in your values.
# Get these from https://dev.twitch.tv/console after creating an app.
# Set redirect URI to: http://localhost:4747/auth/callback

TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Your Twitch numeric user ID (not username).
# Find it at https://www.streamweasels.com/tools/convert-twitch-username-to-user-id/
TWITCH_USER_ID=
TWITCH_CHANNEL_NAME=
